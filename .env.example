# ============================================================
# ICBCBench / FinHLE Evaluation Toolkit 环境变量示例
#
# 使用方式：
#   1. 复制本文件为 .env
#   2. 填写对应服务的 API Key
#   3. 运行脚本时会自动加载
#
# 注意：.env 文件不应提交到 Git，已加入 .gitignore
# ============================================================

# ---------------------------
# 数据路径
# ---------------------------
# 评估数据根目录，脚本会基于该目录查找客观题/主观题数据
# EVAL_DATA_DIR=/path/to/your/eval_data

# ---------------------------
# Deep Research 客户端
# ---------------------------
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
TAVILY_API_KEY=tvly-...

# ---------------------------
# 通用模型 API（model_clients.py）
# ---------------------------
BOYUE_API_KEY=...
DEEPSEEK_API_KEY=sk-...
UIUI_API_KEY=...
ALLMHUB_API_KEY=...
DASHSCOPE_API_KEY=sk-...
APIYI_API_KEY=...
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_API_KEY2=sk-or-...
TEMP_API_KEY=...
DMX_API_KEY=...
MY_DMX_API_KEY=...
KIMI_API_KEY=sk-...

# ---------------------------
# FACT 引用验证相关
# ---------------------------
# Jina AI Reader API Key，用于网页内容提取
# JINA_API_KEY=jina_...

# 代理配置（如需翻墙访问部分网页或 API）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
